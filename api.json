            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "severity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "source": {
            "type": [
              "null",
              "string"
            ]
          },
          "exceptionSummary": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Olve.Template.Api"
